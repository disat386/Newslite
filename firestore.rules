rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || request.auth.token.email == userId);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'credits', 'updatedAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 256)) &&
             data.credits is number && data.credits >= 0 &&
             data.updatedAt == request.time;
    }

    function isValidGeminiKey(data) {
      return data.keys().hasAll(['key', 'status', 'createdAt', 'addedBy']) &&
             data.key is string && data.key.size() <= 256 &&
             data.status in ['active', 'exhausted'] &&
             data.createdAt == request.time &&
             data.addedBy is string && data.addedBy.size() <= 256;
    }

    // --- Collection Rules ---
    match /gemini_keys/{keyId} {
      // Allow public read for key synchronization across ecosystem nodes
      allow list: if isSignedIn(); // Restricted to signed in users for security
      allow get: if isSignedIn() && (resource == null || resource.data.status == 'active');
      
      // Allow authenticated users to add new keys to the pool
      allow create: if isSignedIn() && isValidGeminiKey(incoming());
      
      // Allow clients to mark keys as invalid or exhausted
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['isWorking', 'status', 'updatedAt'])
      );
      
      allow delete: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      
      // Allow creation during first sync with strict schema validation
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      
      // Update logic partitioned into actions
      allow update: if isOwner(userId) && isValidId(userId) && (
        // Action: Deduct Credits (only allow decreasing or same)
        (incoming().diff(existing()).affectedKeys().hasOnly(['credits', 'updatedAt']) && 
         incoming().credits <= existing().credits) ||
        
        // Action: Profile Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt', 'lastLogin']))
      );
    }
  }
}
