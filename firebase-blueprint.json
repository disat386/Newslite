{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and credits within the Auurio Ecosystem.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "credits": { "type": "integer", "description": "Unified credits for ecosystem tools" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "credits"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Users collection for unified credits"
    }
  }
}
